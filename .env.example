# Postgres / TimescaleDB
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_dev
POSTGRES_DB=platform
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8080
# JWT_SECRET must be at least 32 bytes; rotate per environment.
JWT_SECRET=dev_secret_change_me_at_least_32_bytes_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=1m
LOGIN_LOCK_MAX=5
LOGIN_LOCK_FOR=15m

# Web
WEB_PORT=5173

# Exchange selection: coinbase | binance
EXCHANGE=coinbase

BINANCE_WS_URL=wss://stream.binance.us:9443
BINANCE_REST_URL=https://api.binance.us
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# Ingest — symbols are exchange-native (Binance: BTCUSDT; Coinbase: BTC-USD)
INGEST_SYMBOLS=BTC-USD
INGEST_BATCH_SIZE=200
INGEST_BATCH_INTERVAL=500ms
